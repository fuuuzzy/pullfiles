{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"files": {
		"includes": [
			"**",
			"!!**/dist",
			"!!**/build",
			"!!**/node_modules",
			"!!**/coverage",
			"!!**/.next",
			"!!**/data"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"recommended": true
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "error",
				"useExhaustiveDependencies": "warn"
			},
			"suspicious": {
				"noExplicitAny": "error",
				"noConsole": "warn"
			},
			"complexity": {
				"noForEach": "warn",
				"useFlatMap": "error"
			},
			"style": {
				"useImportType": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	}
}
